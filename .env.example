# --- Core (required) ---
# Postgres connection string. On Railway, reference the Postgres plugin, e.g.
# ${{ Postgres.DATABASE_URL }} (private URL — no SSL) or the public URL (needs SSL).
DATABASE_URL=postgres://user:pass@localhost:5432/jaysmart
# Set to "true" when DATABASE_URL points at a managed Postgres that uses a
# self-signed TLS cert (Railway public URL, Supabase, etc.). Omit for the
# Railway private URL or local Postgres.
DATABASE_SSL=false
# 32+ random characters. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-random-32-plus-chars
# Public base URL of the deployed site (used for SEO, sitemap, WhatsApp links).
# On Railway set this to your service domain, e.g. https://your-app.up.railway.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Media storage (required in production) ---
# Media (laptop images) must live in object storage, because Railway's
# filesystem is ephemeral (wiped on every deploy/restart). Use any S3-compatible
# bucket (AWS S3, Cloudflare R2, etc.). Locally these can be left blank to fall
# back to on-disk storage.
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Storefront ---
# WhatsApp number in international format without "+" (e.g. 2348012345678).
NEXT_PUBLIC_WHATSAPP_NUMBER=2348012345678

# --- First admin user (seeded on first boot if no users exist) ---
ADMIN_EMAIL=admin@jaysmart.ng
ADMIN_PASSWORD=change-me-on-first-deploy
